.env
*.env
telegram.env
config/telegram.env
secrets/
credentials/
private/
.private/
*.key
*.pem
*.p12
*.crt
*.csr
*.ovpn
id_rsa
id_ed25519

# Tokens / credential dumps
*token*
*secret*
*credential*
*.kdbx

# Private backups and archives
Real_Backups/
backups/
backup/
restore-test/
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar
*.bak
*.backup
*.dump

# Databases and local state
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
state/
cache/
tmp/
temp/

# Logs and reports
*.log
logs/
reports/private/
*.out
*.err

# OS and editor files
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Python/runtime files
__pycache__/
*.pyc
.venv/
venv/
