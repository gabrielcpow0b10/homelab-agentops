# HomeLab AgentOps — public example environment file
# Copy this file to .env only for local testing.
# Never commit a real .env file.

# ============================================
# ACTIVE — read by the public toolkit today
# ============================================

# NAS checks: halo-doctor.sh and halo-status.sh
HALO_NAS_ENABLED=false
HALO_NAS_MOUNT=/mnt/example-nas

# Non-destructive backup preview
HALO_BACKUP_SOURCE=.
HALO_BACKUP_TARGET=./backup-output-example

# ============================================
# ROADMAP — declared but NOT yet wired to code
# ============================================

HALO_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

HALO_LOCAL_AI_ENABLED=false
HALO_MODEL_PROVIDER=ollama
HALO_MODEL_NAME=replace_me
