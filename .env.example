# HomeLab AgentOps - public example environment file
# Copy this file to .env for local testing.
# Never commit a real .env file.

# General behavior
HALO_MODE=local
HALO_PROFILE=default
HALO_COLOR=true

# Optional paths. Use your own local paths.
HALO_BACKUP_TARGET=./backups
HALO_REPORT_DIR=./reports
HALO_LOG_DIR=./logs

# Optional NAS settings. Leave disabled unless you know what you are doing.
HALO_NAS_ENABLED=false
HALO_NAS_MOUNT=/mnt/example-nas
HALO_NAS_SAFE_MODE=true

# Optional Telegram settings. Do not use real values in public repositories.
HALO_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Optional local AI roadmap settings. Not required for v0.3.
HALO_LOCAL_AI_ENABLED=false
HALO_MODEL_PROVIDER=ollama
HALO_MODEL_NAME=replace_me
